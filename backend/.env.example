# Copy to .env and edit. Never commit secrets.

# Where this backend listens
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Normalizer service (separate teammate). Override per environment.
NORMALIZER_URL=http://127.0.0.1:9000
NORMALIZER_TIMEOUT_S=20

# HTTP retry behavior when calling normalizer
NORMALIZER_MAX_RETRIES=2
NORMALIZER_RETRY_BACKOFF_S=0.5

# SQLite file path. Relative to backend/
DATABASE_URL=sqlite:///./tickets.db

# Safety: if true, /sort-ticket raises 500 when safety rule fails (loud).
# If false, the response is returned with human_review_required=true and a sanitized summary.
SAFETY_FAIL_LOUD=true
